{
  "name": "ecommerce-backend",
  "version": "1.0.0",
  "description": "Secure, scalable MERN E-commerce platform backend",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev-db": "node devServer.js",
    "data:import": "node seeder.js",
    "data:destroy": "node seeder.js -d",
    "build": "npm install --prefix frontend && npm run build --prefix frontend"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "multer": "^1.4.5-lts.1",
    "stripe": "^15.11.0"
  },
  "devDependencies": {
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.3"
  },
  "author": "Antigravity",
  "license": "ISC"
}
